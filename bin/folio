#!/usr/bin/env bash
set -euo pipefail

# ── folio — knowledge management CLI (amendments model) ────────────
# No .folio file. User-scoped. Global config in ~/.config/folio/config.yml.
# One active amendment at a time. Amendments are git worktrees.
# ───────────────────────────────────────────────────────────────────

FOLIO_HOME="$HOME/.config/folio"
STORE_DIR="$FOLIO_HOME/stores"        # base clone lives here
AMEND_DIR="$STORE_DIR/amendments"     # amendment worktrees
CONFIG_FILE="$FOLIO_HOME/config.yml"
BASE_REPO="$STORE_DIR/.main"          # canonical clone (shared .git)

# ── helpers ────────────────────────────────────────────────────────

die() { echo "folio: $*" >&2; exit 1; }

ensure_folio_home() {
  mkdir -p "$FOLIO_HOME" "$STORE_DIR" "$AMEND_DIR"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    cat > "$CONFIG_FILE" <<EOF
remote: jubalm/folio
store: git
active:
EOF
  fi
}

read_config() {
  local key="$1"
  grep "^$key:" "$CONFIG_FILE" | head -1 | sed "s/^$key: *//"
}

write_config() {
  local key="$1" value="$2"
  if grep -q "^$key:" "$CONFIG_FILE"; then
    sed -i '' "s|^$key:.*|$key: $value|" "$CONFIG_FILE"
  else
    echo "$key: $value" >> "$CONFIG_FILE"
  fi
}

topic_to_slug() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//'
}

check_gh() {
  if ! command -v gh &>/dev/null; then
    die "gh CLI not found. Install from https://cli.github.com"
  fi
}

# ── base clone (lazy bootstrap) ────────────────────────────────────

ensure_base() {
  local remote="${1:-$(read_config remote)}"
  [[ -z "$remote" ]] && die "No remote configured. Run 'folio bind <ns/repo>'."

  if [[ -d "$BASE_REPO/.git" ]]; then
    # Already cloned — fetch to stay warm (don't block on failure)
    git -C "$BASE_REPO" fetch origin main --quiet 2>/dev/null || true
    return 0
  fi

  echo "Initializing shared clone..."
  git clone --quiet "git@github.com:${remote}.git" "$BASE_REPO" || die \
    "Failed to clone $remote. Check access and try 'folio bind' again."
  git -C "$BASE_REPO" config extensions.worktreeConfig true
}

# ── active amendment helpers ───────────────────────────────────────

get_active() {
  local active
  active="$(read_config active)"
  [[ -z "$active" || "$active" == "null" ]] && return 1
  echo "$active"
  return 0
}

set_active() { write_config active "$1"; }

clear_active() { write_config active ""; }

amendment_path() {
  local slug
  slug="$(topic_to_slug "$1")"
  echo "$AMEND_DIR/$slug"
}

# ── bind ───────────────────────────────────────────────────────────

cmd_bind() {
  local remote="${1:-}"
  [[ -z "$remote" ]] && die "Usage: folio bind <ns/repo>"

  local current_remote
  current_remote="$(read_config remote || echo "")"

  if [[ "$current_remote" == "$remote" ]]; then
    echo "Already bound to $remote."
    return 0
  fi

  if [[ -n "$current_remote" && "$current_remote" != "jubalm/folio" ]]; then
    local force=false
    for a in "$@"; do [[ "$a" == "--force" ]] && force=true; done
    if ! $force; then
      die "Currently bound to $current_remote. All amendments will be lost. Use --force to re-bind."
    fi
  fi

  # Auth check before any git work
  echo "Checking access to $remote..."
  if ! git ls-remote "git@github.com:${remote}.git" HEAD &>/dev/null; then
    die "Cannot access $remote. Check your SSH setup or repo URL. Run: gh auth status"
  fi

  ensure_folio_home

  # If base already exists from a different remote, nuke it
  if [[ -d "$BASE_REPO/.git" ]]; then
    local existing_remote=""
    existing_remote="$(git -C "$BASE_REPO" remote get-url origin 2>/dev/null || echo "")"
    if [[ "$existing_remote" != "git@github.com:${remote}.git" ]]; then
      echo "Old clone points to a different remote. Re-cloning..."
      rm -rf "$BASE_REPO"
    fi
  fi

  write_config remote "$remote"
  ensure_base "$remote"

  # Fast-forward main checkout
  git -C "$BASE_REPO" checkout main --quiet 2>/dev/null || \
    git -C "$BASE_REPO" checkout origin/main --quiet
  git -C "$BASE_REPO" pull --ff-only origin main --quiet 2>/dev/null || \
    echo "  (main behind remote — run 'folio sync' to catch up)"

  echo "✓ Bound to $remote."
}

# ── switch ─────────────────────────────────────────────────────────

cmd_switch() {
  ensure_folio_home
  ensure_base

  # No args → list amendments
  if [[ $# -eq 0 ]]; then
    local active=""
    active="$(get_active || echo "")"
    local found=false

    printf "  %-25s %-8s %s\n" "AMENDMENT" "STATUS" "PR"
    for dir in "$AMEND_DIR"/*/; do
      [[ -d "$dir" ]] || continue
      local topic
      topic="$(basename "$dir")"
      found=true

      local status="clean"
      if ! git -C "$dir" diff --quiet 2>/dev/null || \
         ! git -C "$dir" diff --cached --quiet 2>/dev/null || \
         [[ -n "$(git -C "$dir" ls-files --others --exclude-standard 2>/dev/null)" ]]; then
        status="dirty"
      fi

      local pr_info=""
      local branch
      branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
      if [[ -n "$branch" && "$branch" != "HEAD" ]]; then
        local remote_branch
        remote_branch="$(echo "$branch" | sed 's|^refs/heads/||')"
        local pr_num=""
        pr_num="$(gh pr list --repo "$(read_config remote)" \
          --head "$remote_branch" --state open \
          --json number --jq '.[0].number' 2>/dev/null || echo "")"
        [[ -n "$pr_num" && "$pr_num" != "null" ]] && pr_info="PR #$pr_num"
      fi

      local marker=" "
      [[ "$topic" == "$active" ]] && marker="*"
      printf "  %s%-24s %-8s %s\n" "$marker" "$topic" "$status" "$pr_info"
    done

    if ! $found; then
      echo "No amendments. Run 'folio switch -c <topic>' to start one."
    fi
    return 0
  fi

  # Parse flags
  local create=false
  local force=false
  local topic=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -c|--create) create=true; shift ;;
      --force) force=true; shift ;;
      *) topic="$(topic_to_slug "$1")"; shift ;;
    esac
  done

  [[ -z "$topic" ]] && die "Usage: folio switch <topic> | folio switch -c <topic>"

  local path
  path="$(amendment_path "$topic")"

  if [[ -d "$path" ]]; then
    # Amendment exists
    local branch
    branch="$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"

    # Check if branch is merged to main (stale, want to re-open)
    local remote="$(read_config remote)"
    git -C "$BASE_REPO" fetch origin main --quiet 2>/dev/null || true
    local is_merged=false
    if [[ -n "$branch" && "$branch" != "HEAD" ]]; then
      # Check if the remote branch is merged into main
      if git -C "$BASE_REPO" branch -r --merged origin/main 2>/dev/null | grep -q "origin/$branch"; then
        is_merged=true
      fi
    fi

    if $is_merged; then
      if $create && $force; then
        echo "Branch '$branch' was merged to main. Deleting and creating fresh..."
        git -C "$BASE_REPO" branch -D "$branch" 2>/dev/null || true
        git push origin --delete "$branch" 2>/dev/null || true
        rm -rf "$path"
        # Fall through to create below
      elif $create; then
        die "amendment '$topic' already exists and was merged to main. Use --force to delete and create fresh."
      elif ! $create; then
        die "amendment '$topic' already exists and was merged to main. Use 'switch -c $topic --force' to start a fresh one."
      fi
    elif [[ -n "$branch" && "$branch" != "HEAD" ]]; then
      # Open draft — just switch and rebase
      if $create && ! $force; then
        # It's an existing draft, just switch to it
        true
      fi
      # Rebase onto latest main
      echo "Rebasing $topic onto main..."
      if ! git -C "$path" rebase origin/main --quiet 2>/dev/null; then
        die "Rebase conflict in $topic. Resolve in $path/leaves/ then re-run 'folio sync'."
      fi
      git -C "$path" pull --rebase --quiet 2>/dev/null || true
      set_active "$topic"
      echo "✓ Switched to amendment '$topic'."
      return 0
    fi
  fi

  # Create new amendment worktree
  if $create; then
    local slug
    slug="$(topic_to_slug "$topic")"
    path="$AMEND_DIR/$slug"

    if [[ -d "$path" ]]; then
      die "amendment '$slug' already exists. Delete it with 'folio drop $slug' first."
    fi

    mkdir -p "$AMEND_DIR"

    local remote="$(read_config remote)"
    ensure_base "$remote"

    # Ensure main is fresh
    git -C "$BASE_REPO" checkout main --quiet 2>/dev/null || true
    git -C "$BASE_REPO" pull --ff-only origin main --quiet 2>/dev/null || true

    local branch="amend/$slug"
    echo "Creating amendment worktree for '$slug'..."

    # Create a worktree at the amendment path, on a new branch off main
    git -C "$BASE_REPO" worktree add -b "$branch" "$path" origin/main --quiet 2>/dev/null || \
      die "Failed to create worktree for '$slug'."

    set_active "$slug"
    echo "✓ Amendment '$slug' created."
    echo "  leaves: $path/leaves/"
    return 0
  fi

  # No --create and not found
  die "amendment '$topic' not found. Use 'folio switch -c $topic' to create one."
}

# ── status ─────────────────────────────────────────────────────────

cmd_status() {
  ensure_folio_home

  local active=""
  active="$(get_active || echo "")"

  if [[ -z "$active" ]]; then
    echo "on main — no open amendments."

    # Check if main checkout is dirty (informational, not blocking)
    local leaves="$BASE_REPO/leaves"
    if [[ -d "$leaves" ]]; then
      if ! git -C "$BASE_REPO" diff --quiet -- leaves/ 2>/dev/null || \
         ! git -C "$BASE_REPO" diff --cached --quiet -- leaves/ 2>/dev/null; then
        echo "  (uncommitted edits in store/leaves/ — did you mean to amend?)"
      fi
    fi

    local remote
    remote="$(read_config remote || echo "")"
    if [[ -n "$remote" ]]; then
      local behind=0
      if git -C "$BASE_REPO" rev-parse --verify origin/main &>/dev/null 2>/dev/null; then
        behind="$(git -C "$BASE_REPO" rev-list --count HEAD..origin/main 2>/dev/null || echo 0)"
      fi
      [[ "$behind" -gt 0 ]] && echo "  behind remote by $behind commit(s). Run 'folio sync'."
    fi
    return 0
  fi

  # In an amendment
  echo "amendment:    $active"
  local path
  path="$(amendment_path "$active")"

  if [[ ! -d "$path" ]]; then
    echo "  (worktree missing — run 'folio switch -c $active' to recreate)"
    return 0
  fi

  local branch
  branch="$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"
  echo "branch:       $branch"

  # Dirty state
  if ! git -C "$path" diff --quiet 2>/dev/null || \
     ! git -C "$path" diff --cached --quiet 2>/dev/null || \
     [[ -n "$(git -C "$path" ls-files --others --exclude-standard 2>/dev/null)" ]]; then
    echo "state:        dirty"
    git -C "$path" status --short 2>/dev/null | head -10 | sed 's/^/  /'
  else
    echo "state:        clean"
  fi

  # Behind count
  if git -C "$BASE_REPO" rev-parse --verify origin/main &>/dev/null 2>/dev/null; then
    local behind=0
    behind="$(git -C "$BASE_REPO" rev-list --count HEAD..origin/main 2>/dev/null || echo 0)"
    [[ "$behind" -gt 0 ]] && echo "  behind main by $behind commit(s)"
  fi

  # PR
  local remote_url
  remote_url="$(read_config remote)"
  if command -v gh &>/dev/null && [[ -n "$remote_url" ]]; then
    local pr_num
    pr_num="$(gh pr list --repo "$remote_url" --head "$branch" --state open \
      --json number --jq '.[0].number' 2>/dev/null || echo "")"
    if [[ -n "$pr_num" ]]; then
      echo "pr:           https://github.com/$remote_url/pull/$pr_num"
    fi
  fi
}

# ── sync ───────────────────────────────────────────────────────────

cmd_sync() {
  check_gh

  ensure_folio_home
  local remote
  remote="$(read_config remote)"
  [[ -z "$remote" ]] && die "No remote configured. Run 'folio bind <ns/repo>'."
  ensure_base "$remote"

  # Always surface open PRs first
  local prs
  prs="$(gh pr list --repo "$remote" --state open \
    --json number,title,headRefName --jq \
    '.[] | "  #\(.number)  \(.title)  (\(.headRefName))"' 2>/dev/null || echo "")"
  if [[ -n "$prs" ]]; then
    echo "Open PRs:"
    echo "$prs"
    echo ""
  fi

  local active=""
  active="$(get_active || echo "")"

  # ── on main mode (no active amendment) ────────────────────────
  if [[ -z "$active" ]]; then
    echo "Pulling latest from $remote..."
    git -C "$BASE_REPO" pull --ff-only origin main --quiet 2>/dev/null || die \
      "Failed to pull main. Check network."

    # Check for uncommitted changes in main checkout
    if ! git -C "$BASE_REPO" diff --quiet -- leaves/ 2>/dev/null || \
       ! git -C "$BASE_REPO" diff --cached --quiet -- leaves/ 2>/dev/null; then
      echo "  (uncommitted edits in store/leaves/ — did you mean to amend?)"
    fi

    echo "✓ on main, synced."
    return 0
  fi

  # ── in amendment mode ─────────────────────────────────────────
  local path
  path="$(amendment_path "$active")"
  [[ -d "$path" ]] || die "Worktree for '$active' not found. Run 'folio switch -c $active'."

  cd "$path"

  local branch
  branch="$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
  [[ -z "$branch" || "$branch" == "HEAD" ]] && die "Amendment '$active' is not on a branch."

  # Resolve -m flag
  local msg=""
  if [[ "${1:-}" == "-m" ]]; then
    msg="${2:-}"
    [[ -z "$msg" ]] && die "Message required with -m."
  else
    msg="amend: $active"
  fi

  # Check if anything to commit
  local has_changes=false
  if ! git -C "$path" diff --quiet 2>/dev/null || \
     ! git -C "$path" diff --cached --quiet 2>/dev/null || \
     [[ -n "$(git -C "$path" ls-files --others --exclude-standard 2>/dev/null)" ]]; then
    has_changes=true
  fi

  # Commit first (if dirty)
  if $has_changes; then
    git -C "$path" add -A
    git -C "$path" commit -m "$msg" --quiet
    echo "Committed: $msg"
  fi

  # Rebase onto main (always, to keep linear history)
  echo "Rebasing '$branch' onto main..."
  if ! git -C "$path" rebase origin/main --quiet 2>/dev/null; then
    die "REBASE CONFLICT in $active — resolve in $path/ then re-run 'folio sync'."
  fi

  if ! $has_changes; then
    # Check if anything actually needs pushing (branch may be up to date)
    local branch_remote
    branch_remote="$(git -C "$path" rev-parse "origin/$branch" 2>/dev/null || echo "")"
    local branch_local
    branch_local="$(git -C "$path" rev-parse HEAD 2>/dev/null || echo "")"
    if [[ "$branch_local" == "$branch_remote" ]]; then
      echo "Everything up to date in '$active'."
      return 0
    fi
  fi

  # Force-push (draft branch, safe to rewrite)
  if ! git -C "$path" push --force origin "$branch" --quiet 2>&1; then
    die "Push failed. Check network and access."
  fi

  # Create or update draft PR
  local pr_num
  pr_num="$(gh pr list --repo "$remote" --head "$branch" --state open \
    --json number --jq '.[0].number' 2>/dev/null || echo "")"

  if [[ -z "$pr_num" ]]; then
    local pr_title="${msg%%$'\n'*}"
    local pr_url
    pr_url="$(gh pr create --repo "$remote" --base main --head "$branch" \
      --draft --title "$pr_title" --body "$msg" 2>&1)" || die "PR creation failed."
    pr_num="$(echo "$pr_url" | grep -oE '[0-9]+$' || echo "")"
    echo "✓ Draft PR #$pr_num created"
  else
    if $has_changes; then
      gh pr edit --repo "$remote" "$pr_num" --title "${msg%%$'\n'*}" --body "$msg" 2>/dev/null || true
    fi
    echo "✓ Draft PR #$pr_num updated"
  fi

  echo "  https://github.com/$remote/pull/$pr_num"
}

# ── drop ───────────────────────────────────────────────────────────

cmd_drop() {
  local topic="" force=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=true; shift ;;
      *) topic="$(topic_to_slug "$1")"; shift ;;
    esac
  done

  [[ -z "$topic" ]] && die "Usage: folio drop <topic> [--force]"

  local path
  path="$(amendment_path "$topic")"
  [[ ! -d "$path" ]] && die "Amendment '$topic' not found."

  local branch
  branch="$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
  local remote
  remote="$(read_config remote)"

  # Check for open PR
  local pr_num=""
  if [[ -n "$branch" && "$branch" != "HEAD" ]] && command -v gh &>/dev/null && [[ -n "$remote" ]]; then
    pr_num="$(gh pr list --repo "$remote" --head "$branch" --state open \
      --json number --jq '.[0].number' 2>/dev/null || echo "")"
  fi

  # Check for local dirty state
  local dirty=false
  if ! git -C "$path" diff --quiet 2>/dev/null || \
     ! git -C "$path" diff --cached --quiet 2>/dev/null || \
     [[ -n "$(git -C "$path" ls-files --others --exclude-standard 2>/dev/null)" ]]; then
    dirty=true
  fi

  # Warning message depends on state
  if [[ -n "$pr_num" ]]; then
    if $dirty; then
      echo "  amendment '$topic' has an open draft PR (#$pr_num) and uncommitted changes."
    else
      echo "  amendment '$topic' has an open draft PR (#$pr_num)."
    fi
    echo "  --force will close the PR, delete the remote branch, and remove local worktree."
  elif $dirty; then
    echo "  amendment '$topic' has uncommitted changes. --force discards them."
  else
    echo "  amendment '$topic' is clean."
  fi

  if ! $force; then
    die "Use --force to confirm deletion."
  fi

  # Close PR if open
  if [[ -n "$pr_num" ]]; then
    gh pr close --repo "$remote" "$pr_num" 2>/dev/null || true
    echo "  Closed PR #$pr_num."
  fi

  # Delete remote branch
  if [[ -n "$branch" && "$branch" != "HEAD" ]]; then
    git push origin --delete "$branch" 2>/dev/null || true
    echo "  Deleted remote branch '$branch'."
  fi

  # Remove worktree via git (cleaner than rm -rf)
  git -C "$BASE_REPO" worktree remove "$path" --force 2>/dev/null || \
    rm -rf "$path"

  echo "✓ Dropped amendment '$topic'."

  # Clear active if this was the active amendment
  local active=""
  active="$(get_active || echo "")"
  if [[ "$active" == "$topic" ]]; then
    clear_active
    echo "  (active cleared — on main now)"
  fi
}

# ── list ───────────────────────────────────────────────────────────

cmd_list() {
  ensure_folio_home
  ensure_base 2>/dev/null || true

  local active=""
  active="$(get_active || echo "")"
  local found=false

  printf "  %-25s %-8s %s\n" "AMENDMENT" "STATUS" "PR"
  for dir in "$AMEND_DIR"/*/; do
    [[ -d "$dir" ]] || continue
    local topic
    topic="$(basename "$dir")"
    found=true

    local status="clean"
    if ! git -C "$dir" diff --quiet 2>/dev/null || \
       ! git -C "$dir" diff --cached --quiet 2>/dev/null || \
       [[ -n "$(git -C "$dir" ls-files --others --exclude-standard 2>/dev/null)" ]]; then
      status="dirty"
    fi

    local pr_info=""
    local branch
    branch="$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
    if [[ -n "$branch" && "$branch" != "HEAD" ]] && command -v gh &>/dev/null; then
      local remote
      remote="$(read_config remote)"
      if [[ -n "$remote" ]]; then
        local pr_num=""
        pr_num="$(gh pr list --repo "$remote" \
          --head "$branch" --state open \
          --json number --jq '.[0].number' 2>/dev/null || echo "")"
        [[ -n "$pr_num" && "$pr_num" != "null" ]] && pr_info="PR #$pr_num"
      fi
    fi

    local marker=" "
    [[ "$topic" == "$active" ]] && marker="*"

    printf "  %s%-24s %-8s %s\n" "$marker" "$topic" "$status" "$pr_info"
  done

  if ! $found; then
    echo "No amendments. Run 'folio switch -c <topic>' to start one."
  fi
}

# ── dash ───────────────────────────────────────────────────────────

cmd_dash() {
  ensure_folio_home
  [[ -d "$BASE_REPO/.git" ]] || ensure_base

  if ! command -v node &>/dev/null; then
    die "folio dash requires Node.js. Install from https://nodejs.org/ or via your package manager."
  fi

  local port="8765"
  local no_open=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port)
        shift
        [[ $# -gt 0 ]] || die "Usage: folio dash [--port <port>] [--no-open]"
        port="$1"
        shift
        ;;
      --no-open)
        no_open=true
        shift
        ;;
      *)
        die "Usage: folio dash [--port <port>] [--no-open]"
        ;;
    esac
  done

  local token=""
  if command -v openssl &>/dev/null; then
    token="$(openssl rand -hex 16)"
  else
    token="$(date +%s)-$$"
  fi

  local script
  script="$(mktemp "${TMPDIR:-/tmp}/folio-dash.XXXXXX")"
  trap 'rm -f "$script"' EXIT

  cat > "$script" <<'NODE'
const http = require('http');
const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');

const PORT = Number(process.env.FOLIO_DASH_PORT || 8765);
const TOKEN = process.env.FOLIO_DASH_TOKEN;
const FOLIO = process.env.FOLIO_BIN_SELF || 'folio';
const FOLIO_HOME = process.env.FOLIO_HOME;
const CONFIG_FILE = process.env.CONFIG_FILE;
const BASE_REPO = process.env.BASE_REPO;
const AMEND_DIR = process.env.AMEND_DIR;

function sh(cmd, args, opts = {}) {
  const r = spawnSync(cmd, args, { encoding: 'utf8', cwd: opts.cwd, env: process.env });
  return { ok: r.status === 0, status: r.status, stdout: (r.stdout || '').trim(), stderr: (r.stderr || '').trim() };
}
function git(args, cwd = BASE_REPO) { return sh('git', args, { cwd }); }
function gh(args) { return sh('gh', args); }
function folio(args) { return sh(FOLIO, args); }
function parseJson(text, fallback) { try { return JSON.parse(text); } catch { return fallback; } }
function readConfig() {
  const out = {};
  try {
    for (const line of fs.readFileSync(CONFIG_FILE, 'utf8').split(/\r?\n/)) {
      const m = line.match(/^([^:#]+):\s*(.*)$/);
      if (m) out[m[1].trim()] = m[2].trim();
    }
  } catch {}
  return out;
}
function writeConfigKey(key, value) {
  let text = '';
  try { text = fs.readFileSync(CONFIG_FILE, 'utf8'); } catch {}
  const re = new RegExp(`^${key}:.*$`, 'm');
  if (re.test(text)) text = text.replace(re, `${key}: ${value}`);
  else text += `${text.endsWith('\n') || !text ? '' : '\n'}${key}: ${value}\n`;
  fs.writeFileSync(CONFIG_FILE, text);
}
function slug(s) {
  return String(s || '').toLowerCase().replace(/[^a-z0-9]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
}
function topicFromBranch(branch) {
  return String(branch || '').replace(/^amend\//, '').replace(/^folio\//, 'folio-');
}
function isDirty(cwd) {
  return git(['status', '--porcelain'], cwd).stdout.length > 0;
}
function changedFiles(cwd) {
  const base = git(['merge-base', 'HEAD', 'origin/main'], cwd).stdout || 'origin/main';
  const committed = git(['diff', '--name-status', `${base}...HEAD`], cwd).stdout.split('\n').filter(Boolean);
  const local = git(['status', '--porcelain'], cwd).stdout.split('\n').filter(Boolean);
  return { committed, local };
}
function localAmendments() {
  const rows = [];
  if (!fs.existsSync(AMEND_DIR)) return rows;
  for (const name of fs.readdirSync(AMEND_DIR)) {
    const p = path.join(AMEND_DIR, name);
    if (!fs.existsSync(path.join(p, '.git'))) continue;
    const branch = git(['rev-parse', '--abbrev-ref', 'HEAD'], p).stdout;
    const files = changedFiles(p);
    rows.push({
      topic: name,
      branch,
      path: p,
      local: true,
      dirty: isDirty(p),
      changedCount: files.committed.length + files.local.length,
      lastCommit: git(['log', '-1', '--pretty=%h %cr %s'], p).stdout,
    });
  }
  return rows;
}
function openPrs(remote) {
  if (!remote) return [];
  const r = gh(['pr', 'list', '--repo', remote, '--state', 'open', '--json', 'number,title,headRefName,isDraft,url,updatedAt']);
  return r.ok ? parseJson(r.stdout, []) : [];
}
function prForBranch(remote, branch) {
  if (!remote || !branch) return null;
  const r = gh(['pr', 'list', '--repo', remote, '--head', branch, '--state', 'all', '--json', 'number,title,headRefName,isDraft,state,url,updatedAt', '--jq', '.[0]']);
  return r.ok && r.stdout && r.stdout !== 'null' ? parseJson(r.stdout, null) : null;
}
function combinedAmendments() {
  const cfg = readConfig();
  const byBranch = new Map();
  for (const a of localAmendments()) {
    const pr = prForBranch(cfg.remote, a.branch);
    byBranch.set(a.branch, { ...a, pr });
  }
  for (const pr of openPrs(cfg.remote)) {
    if (byBranch.has(pr.headRefName)) {
      byBranch.set(pr.headRefName, { ...byBranch.get(pr.headRefName), pr });
    } else {
      byBranch.set(pr.headRefName, {
        topic: topicFromBranch(pr.headRefName),
        branch: pr.headRefName,
        local: false,
        dirty: false,
        changedCount: null,
        lastCommit: '',
        pr,
      });
    }
  }
  return [...byBranch.values()].sort((a, b) => String(b.pr?.updatedAt || '').localeCompare(String(a.pr?.updatedAt || '')));
}
function status() {
  const cfg = readConfig();
  const rev = git(['rev-parse', '--short', 'HEAD']).stdout;
  const origin = git(['rev-parse', '--short', 'origin/main']).stdout;
  const counts = git(['rev-list', '--left-right', '--count', 'HEAD...origin/main']).stdout.split(/\s+/);
  const prs = openPrs(cfg.remote);
  return {
    config: cfg,
    baseRepo: BASE_REPO,
    active: cfg.active || '',
    main: { rev, origin, ahead: Number(counts[0] || 0), behind: Number(counts[1] || 0), dirty: isDirty(BASE_REPO) },
    gh: gh(['auth', 'status']).ok,
    openPrCount: prs.length,
    localAmendmentCount: localAmendments().length,
  };
}
function detail(query) {
  const cfg = readConfig();
  const topic = slug(query.get('topic') || '');
  const prNum = query.get('pr') || '';
  const item = combinedAmendments().find(a => a.topic === topic || String(a.pr?.number || '') === prNum || a.branch === query.get('branch'));
  if (!item) throw Object.assign(new Error('amendment not found'), { status: 404 });
  const out = { item, files: { committed: [], local: [] }, diff: '', pr: item.pr || null, comments: [] };
  if (item.local && item.path) {
    out.files = changedFiles(item.path);
    const base = git(['merge-base', 'HEAD', 'origin/main'], item.path).stdout || 'origin/main';
    out.diff = git(['diff', '--find-renames', `${base}...HEAD`], item.path).stdout || '(no committed diff)';
    if (isDirty(item.path)) {
      const localDiff = git(['diff'], item.path).stdout;
      if (localDiff) out.diff += `\n\n--- uncommitted diff ---\n${localDiff}`;
    }
  } else if (item.pr?.number) {
    out.diff = gh(['pr', 'diff', String(item.pr.number), '--repo', cfg.remote]).stdout;
  }
  if (item.pr?.number) {
    const view = gh(['pr', 'view', String(item.pr.number), '--repo', cfg.remote, '--json', 'number,title,body,state,isDraft,url,headRefName,comments,reviews']);
    if (view.ok) out.pr = parseJson(view.stdout, item.pr);
  }
  return out;
}
function cleanupMergedLocal() {
  const removed = [];
  git(['fetch', 'origin', 'main', '--quiet']);
  for (const a of localAmendments()) {
    if (!a.branch || a.branch === 'HEAD') continue;
    const merged = git(['branch', '-r', '--merged', 'origin/main'], BASE_REPO).stdout.includes(`origin/${a.branch}`);
    const pr = prForBranch(readConfig().remote, a.branch);
    if (merged || pr?.state === 'MERGED' || pr?.state === 'CLOSED') {
      git(['worktree', 'remove', a.path, '--force'], BASE_REPO);
      removed.push(a.topic);
      if (readConfig().active === a.topic) writeConfigKey('active', '');
    }
  }
  git(['worktree', 'prune'], BASE_REPO);
  return { removed };
}
function act(payload) {
  const cfg = readConfig();
  const action = payload.action;
  if (action === 'sync-main') return folio(['sync']);
  if (action === 'sync-amendment') {
    if (!payload.topic) throw new Error('topic required');
    writeConfigKey('active', slug(payload.topic));
    return folio(['sync', '-m', payload.message || `folio dash: sync ${slug(payload.topic)}`]);
  }
  if (action === 'ready') {
    if (!payload.pr) throw new Error('pr required');
    return gh(['pr', 'ready', String(payload.pr), '--repo', cfg.remote]);
  }
  if (action === 'merge') {
    if (!payload.pr || payload.confirm !== `merge #${payload.pr}`) throw new Error(`confirmation required: merge #${payload.pr}`);
    const view = gh(['pr', 'view', String(payload.pr), '--repo', cfg.remote, '--json', 'title,body,headRefName']);
    if (!view.ok) return view;
    const pr = parseJson(view.stdout, {});
    const merge = gh(['pr', 'merge', String(payload.pr), '--repo', cfg.remote, '--squash', '--delete-branch', '--subject', `${pr.title} (#${payload.pr})`, '--body', pr.body || '']);
    if (!merge.ok) return merge;
    git(['pull', '--ff-only', 'origin', 'main', '--quiet'], BASE_REPO);
    const topic = topicFromBranch(pr.headRefName);
    const p = path.join(AMEND_DIR, slug(topic));
    if (fs.existsSync(p)) git(['worktree', 'remove', p, '--force'], BASE_REPO);
    if (readConfig().active === slug(topic)) writeConfigKey('active', '');
    return merge;
  }
  if (action === 'drop') {
    if (!payload.topic || payload.confirm !== `drop ${slug(payload.topic)}`) throw new Error(`confirmation required: drop ${slug(payload.topic)}`);
    return folio(['drop', slug(payload.topic), '--force']);
  }
  if (action === 'cleanup') {
    if (payload.confirm !== 'cleanup') throw new Error('confirmation required: cleanup');
    return cleanupMergedLocal();
  }
  throw new Error('unknown action');
}
function send(res, code, data) {
  res.writeHead(code, { 'content-type': 'application/json; charset=utf-8' });
  res.end(JSON.stringify(data, null, 2));
}
function requireToken(req, url) {
  const header = req.headers['x-folio-token'];
  const query = url.searchParams.get('token');
  return header === TOKEN || query === TOKEN;
}

var token = new URLSearchParams(location.search).get('token');
function esc(s){return String(s == null ? '' : s).replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]})}
async function api(path, opts){opts=opts||{};opts.headers=Object.assign({},opts.headers||{}, {'x-folio-token':token}); if(opts.body && typeof opts.body !== 'string'){opts.headers['content-type']='application/json';opts.body=JSON.stringify(opts.body)} var r=await fetch(path,opts); var j=await r.json(); if(!r.ok) throw new Error(j.error||r.statusText); return j;}
async function loadAll(){
  var st=await api('/api/status');
  document.getElementById('health').textContent=(st.config.remote||'unbound')+' · main '+st.main.rev+(st.main.behind?' · behind '+st.main.behind:'')+(st.active?' · active '+st.active:'');
  document.getElementById('status').innerHTML='<b>Status</b><br>Remote: '+esc(st.config.remote)+'<br>Main: '+esc(st.main.rev)+' / origin '+esc(st.main.origin)+'<br>Ahead/behind: '+st.main.ahead+'/'+st.main.behind+'<br>Open PRs: '+st.openPrCount+'<br>Local amendments: '+st.localAmendmentCount+'<br>gh auth: '+(st.gh?'ok':'missing');
  var rows=await api('/api/amendments');
  document.getElementById('list').innerHTML=rows.map(function(r){return '<div class="row" onclick="show(\\''+esc(r.topic)+'\',\''+esc((r.pr&&r.pr.number)||'')+'\\')"><b>'+esc(r.topic)+'</b> '+((r.pr&&r.pr.isDraft)?'<span class="pill draft">draft</span>':'')+(r.dirty?'<span class="pill dirty">dirty</span>':'')+(!r.local?'<span class="pill">remote-only</span>':'')+'<br><span class="muted">'+esc(r.branch)+' '+(r.pr?'· #'+r.pr.number+' '+esc(r.pr.title):'· local only')+'</span></div>'}).join('') || '<p class="muted">No amendments.</p>';
}
async function show(topic, pr){
  var d=await api('/api/detail?topic='+encodeURIComponent(topic)+'&pr='+encodeURIComponent(pr)); var p=d.pr||{};
  var actions='<div class="actions"><button onclick="action({action:\\'sync-amendment\\',topic:\\''+esc(d.item.topic)+'\\'})">Sync</button>';
  if(p.number){actions += '<button onclick="action({action:\\'ready\\',pr:'+p.number+'})">Mark ready</button><button class="danger" onclick="mergePr('+p.number+')">Squash merge</button>';}
  actions += '<button class="danger" onclick="dropTopic(\\''+esc(d.item.topic)+'\\')">Drop</button></div>';
  document.getElementById('detail').innerHTML='<h2>'+esc(d.item.topic)+' '+(p.number?'<span class="pill">#'+p.number+'</span>':'')+'</h2><p class="muted">'+esc(d.item.branch)+' '+(d.item.local?'· '+esc(d.item.path):'· remote-only')+'</p><p>'+(p.url?'<a href="'+esc(p.url)+'">Open on GitHub</a>':'')+'</p>'+actions+'<h3>Files</h3><pre>'+esc([].concat(d.files.committed||[],d.files.local||[]).join('\\n')||'(none)')+'</pre><h3>PR body</h3><pre>'+esc(p.body||'(no PR body)')+'</pre><h3>Diff</h3><pre>'+esc(d.diff||'(no diff)')+'</pre>';
}
async function action(body){try{var out=await api('/api/action',{method:'POST',body:body}); alert(out.stdout||JSON.stringify(out)); await loadAll();}catch(e){alert(e.message)}}
function mergePr(pr){var c=prompt('Type: merge #'+pr); if(c) action({action:'merge',pr:pr,confirm:c});}
function dropTopic(topic){var c=prompt('Type: drop '+topic); if(c) action({action:'drop',topic:topic,confirm:c});}
function cleanup(){var c=prompt('Type: cleanup'); if(c) action({action:'cleanup',confirm:c});}
loadAll().catch(function(e){document.getElementById('health').textContent=e.message});
</script></body></html>`; }

const server = http.createServer((req, res) => {
  const url = new URL(req.url, `http://127.0.0.1:${PORT}`);
  if (!requireToken(req, url)) return send(res, 403, { error: 'bad token' });
  try {
    if (req.method === 'GET' && url.pathname === '/') { res.writeHead(200, { 'content-type': 'text/html; charset=utf-8' }); return res.end(html()); }
    if (req.method === 'GET' && url.pathname === '/api/status') return send(res, 200, status());
    if (req.method === 'GET' && url.pathname === '/api/amendments') return send(res, 200, combinedAmendments());
    if (req.method === 'GET' && url.pathname === '/api/detail') return send(res, 200, detail(url.searchParams));
    if (req.method === 'POST' && url.pathname === '/api/action') {
      let body = '';
      req.on('data', c => body += c);
      req.on('end', () => { try { send(res, 200, act(parseJson(body, {}))); } catch (e) { send(res, e.status || 400, { error: e.message }); } });
      return;
    }
    send(res, 404, { error: 'not found' });
  } catch (e) { send(res, e.status || 500, { error: e.message }); }
});
server.listen(PORT, '127.0.0.1');
NODE

  local url="http://127.0.0.1:${port}/?token=${token}"
  echo "folio dash: $url"
  echo "Ctrl-C to stop."
  if ! $no_open && command -v open &>/dev/null; then
    open "$url" >/dev/null 2>&1 || true
  fi

  FOLIO_DASH_PORT="$port" \
  FOLIO_DASH_TOKEN="$token" \
  FOLIO_HOME="$FOLIO_HOME" \
  CONFIG_FILE="$CONFIG_FILE" \
  BASE_REPO="$BASE_REPO" \
  AMEND_DIR="$AMEND_DIR" \
  FOLIO_BIN_SELF="$0" \
  node "$script"
}

# ── config ─────────────────────────────────────────────────────────

cmd_config() {
  ensure_folio_home
  local key="${1:-}"
  local value="${2:-}"

  if [[ -z "$key" ]]; then
    cat "$CONFIG_FILE"
    return 0
  fi

  if [[ -z "$value" ]]; then
    read_config "$key"
    return 0
  fi

  write_config "$key" "$value"
}

# ── dispatch ───────────────────────────────────────────────────────

case "${1:-}" in
  bind)   shift; cmd_bind "$@" ;;
  switch) shift; cmd_switch "$@" ;;
  sync)   shift; cmd_sync "$@" ;;
  drop)   shift; cmd_drop "$@" ;;
  list)   shift; cmd_list "$@" ;;
  status) shift; cmd_status "$@" ;;
  config) shift; cmd_config "$@" ;;
  dash)   shift; cmd_dash "$@" ;;
  *)
    cat <<EOF
folio — knowledge management CLI

Usage:
  folio bind <ns/repo>         Bind to a knowledge repo (one-time setup)
  folio switch                 List amendments (* = active)
  folio switch <topic>         Switch to an existing amendment
  folio switch -c <topic>      Create a new amendment (--force to re-create)
  folio status                 Show current state (main | amendment)
  folio sync [-m "msg"]        Pull main → rebase → commit → push → draft PR
  folio drop <topic> --force   Delete an amendment (local + remote)
  folio config                 Show global config
  folio config <key> <value>   Set config value
  folio dash [--no-open]       Launch local review/merge dashboard

Edits go in ~/.config/folio/stores/amendments/<topic>/leaves/.
folio sync opens a draft PR; merge via folio dash.
EOF
    exit 1
    ;;
esac

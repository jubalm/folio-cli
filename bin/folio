#!/usr/bin/env bash
set -euo pipefail

# ── folio — knowledge management CLI ───────────────────────────────
# User-scoped. Stores live in ~/.config/folio/stores/.
# Projects carry a .folio pointer file (just the store name).
# The CLI is a git shortcut, not a content processor.
# ───────────────────────────────────────────────────────────────────

FOLIO_HOME="$HOME/.config/folio"
STORE_DIR="$FOLIO_HOME/stores"
CONFIG_FILE="$FOLIO_HOME/config.yml"
REMOTE_REPO="jubalm/folio"

# ── helpers ────────────────────────────────────────────────────────

die() { echo "folio: $*" >&2; exit 1; }

ensure_folio_home() {
  mkdir -p "$FOLIO_HOME" "$STORE_DIR"
  if [[ ! -f "$CONFIG_FILE" ]]; then
    cat > "$CONFIG_FILE" <<EOF
remote: $REMOTE_REPO
store: git
EOF
  fi
}

read_config() {
  local key="$1"
  grep "^$key:" "$CONFIG_FILE" | head -1 | sed "s/^$key: *//"
}

detect_project_root() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/.folio" ]]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

detect_store_name() {
  local project_root
  project_root="$(detect_project_root)" || return 1
  head -1 "$project_root/.folio"
}

# ── store name ─────────────────────────────────────────────────────

make_store_name() {
  local seed="${1:-$PWD}"
  echo "$seed" | md5 | cut -c1-8
}

# ── store (shared clone) ───────────────────────────────────────────

ensure_base() {
  local remote="${1:-$REMOTE_REPO}"
  local base="$STORE_DIR/.main"

  if [[ -d "$base/.git" ]]; then
    git -C "$base" fetch origin main --quiet 2>/dev/null || true
    return 0
  fi

  echo "Initializing shared clone..."
  git clone --quiet "git@github.com:${remote}.git" "$base" || die \
    "Failed to clone $remote."
  git -C "$base" config extensions.worktreeConfig true
}

# ── global gitignore ───────────────────────────────────────────────

setup_global_gitignore() {
  local gi
  gi="$(git config --global core.excludesFile 2>/dev/null || echo "")"

  # Nothing configured — pick a default and set it
  if [[ -z "$gi" ]]; then
    gi="$HOME/.gitignore_global"
    git config --global core.excludesFile "$gi"
  fi

  # Resolve ~ and $HOME if git stored a literal path
  gi="${gi/#\~/$HOME}"

  touch "$gi"
  grep -qx ".folio" "$gi" && return 0

  # Ensure trailing newline if file has content
  [[ -s "$gi" ]] && echo "" >> "$gi"
  echo ".folio" >> "$gi"
}

# ── init ───────────────────────────────────────────────────────────

cmd_init() {
  local label=""
  if [[ "${1:-}" == "--label" ]] || [[ "${1:-}" == "--name" ]]; then
    label="${2:-}"
    [[ -z "$label" ]] && die "Label required with ${1}."
    shift 2 || true
  fi
  [[ -z "$label" ]] && label="$(basename "$PWD")"

  # Check if already initialized from this directory
  local project_root
  project_root="$(detect_project_root)" && die \
    "Already initialized ($project_root/.folio → $(head -1 $project_root/.folio))."

  local name
  name="$(make_store_name)"

  # Hash collision is astronomically unlikely — guard just in case
  if [[ -d "$STORE_DIR/$name" ]] && [[ "$name" != ".main" ]]; then
    die "Store collision: $name (extremely unlikely)."
  fi

  ensure_folio_home
  setup_global_gitignore
  ensure_base "$REMOTE_REPO"

  echo "Adding worktree at $STORE_DIR/$name/ ..."
  git -C "$STORE_DIR/.main" worktree add --detach "$STORE_DIR/$name" origin/main || die \
    "Failed to create worktree. Check that $STORE_DIR/.main exists."

  git -C "$STORE_DIR/$name" config --worktree folio.label "$label"

  echo "$name" > .folio
  echo "✓ Store ready ($label)."
}

# ── sync ────────────────────────────────────────────────────────────

cmd_sync() {
  local project_root store_name store remote
  project_root="$(detect_project_root)" || die \
    "Not initialized. Run 'folio init' from this directory."
  store_name="$(detect_store_name)"
  store="$STORE_DIR/$store_name"
  remote="$(read_config remote)"

  [[ -d "$store" ]] || die "Store '$store_name' not found at $store/. Run 'folio init'."

  cd "$store"

  # ── fetch ──────────────────────────────────────────────────────

  ensure_base "$remote"
  git fetch origin main --quiet 2>/dev/null || die \
    "Cannot reach $remote. Check network."

  # ── surface open PRs ──────────────────────────────────────────

  local prs
  prs="$(gh pr list --repo "$remote" --state open \
    --json number,title,headRefName --jq \
    '.[] | "  #\(.number)  \(.title)  (\(.headRefName))"' 2>/dev/null || echo "")"

  if [[ -n "$prs" ]]; then
    echo "Open PRs:"
    echo "$prs"
    echo ""
  fi

  local draft_branch="folio/$store_name"
  local current_branch
  current_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"

  local dirty=false
  if ! git diff --quiet || ! git diff --cached --quiet || [[ -n "$(git ls-files --others --exclude-standard)" ]]; then
    dirty=true
  fi

  # ── detached HEAD (clean slate) ──────────────────────────────────

  if [[ "$current_branch" == "HEAD" ]]; then
    if ! $dirty; then
      git checkout --detach origin/main --quiet 2>/dev/null || true
      echo "Nothing to push."
      return 0
    fi

    # Resolve -m flag
    local msg=""
    if [[ "${1:-}" == "-m" ]]; then
      msg="${2:-}"
      [[ -z "$msg" ]] && die "Message required with -m."
      shift 2 || true
    else
      echo -n "Message: "
      read -r msg || true
      [[ -z "$msg" ]] && msg="folio draft"
    fi

    echo "Creating draft..."
    git checkout -b "$draft_branch" --quiet
    git add -A
    git commit -m "$msg" --quiet

    echo "Pushing $draft_branch..."
    git push -u origin "$draft_branch" --quiet 2>&1 || die "Push failed."

    local pr_title="${msg%%$'\n'*}"
    local pr_url
    pr_url="$(gh pr create --repo "$remote" --base main --head "$draft_branch" \
      --draft --title "$pr_title" --body "$msg" 2>&1)" || die \
      "PR creation failed."

    local pr_num="$(echo "$pr_url" | grep -oE '[0-9]+$' || echo "")"
    echo "✓ Draft PR #$pr_num opened"
    return 0
  fi

  # ── on draft branch ──────────────────────────────────────────────

  if [[ "$current_branch" == "$draft_branch" ]]; then
    local pr_num
    pr_num="$(gh pr list --repo "$remote" --head "$draft_branch" --state open \
      --json number --jq '.[0].number' 2>/dev/null || echo "")"

    if [[ -z "$pr_num" ]]; then
      # PR was merged or closed — reset
      echo "Draft completed. Resetting..."
      git checkout --detach origin/main --quiet 2>/dev/null || true
      git branch -D "$draft_branch" --quiet 2>/dev/null || true
      echo "Ready for next round."
      return 0
    fi

    # PR is open
    if ! $dirty; then
      echo "Draft up to date (PR #$pr_num)."
      return 0
    fi

    echo "Updating draft PR #$pr_num..."
    git add -A

    local update_msg="draft update"
    if [[ "${1:-}" == "-m" ]]; then
      update_msg="${2:-draft update}"
    fi

    git commit -m "$update_msg" --quiet
    git push origin "$draft_branch" --quiet 2>&1 || die "Push failed."
    echo "✓ Draft updated (PR #$pr_num)."
    return 0
  fi

  # ── unknown branch ───────────────────────────────────────────────

  die "Unexpected branch: $current_branch. Run 'git checkout --detach origin/main' in $store/ manually."
}

# ── list ───────────────────────────────────────────────────────────

cmd_list() {
  ensure_folio_home

  local found=false
  printf "  %-12s %-22s %-8s %s\n" "STORE" "LABEL" "STATUS" "BRANCH"

  for store in "$STORE_DIR"/*/; do
    [[ -d "$store" ]] || continue
    local name="$(basename "$store")"
    [[ "$name" == ".main" ]] && continue

    found=true
    local label="$(git -C "$store" config --worktree folio.label 2>/dev/null || echo "$name")"
    local status="clean"
    local branch="detach"

    if ! git -C "$store" diff --quiet || \
       ! git -C "$store" diff --cached --quiet || \
       [[ -n "$(git -C "$store" ls-files --others --exclude-standard 2>/dev/null)" ]]; then
      status="dirty"
    fi
    branch="$(git -C "$store" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"
    [[ "$branch" == "HEAD" ]] && branch="detach"

    printf "  %-12s %-22s %-8s %s\n" "$name" "$label" "$status" "$branch"
  done

  if ! $found; then
    echo "No stores. Run 'folio init' from a project directory."
  fi
}

# ── status ─────────────────────────────────────────────────────────

cmd_status() {
  local project_root store_name
  project_root="$(detect_project_root)" || die \
    "Not initialized. Run 'folio init' from this directory."
  store_name="$(detect_store_name)"
  local store="$STORE_DIR/$store_name"

  echo "Project:  $project_root"
  echo "Store:    $store"

  git -C "$store" rev-parse --git-dir &>/dev/null || die \
    "Store at $store is not a valid git worktree."

  if git -C "$store" diff --quiet && git -C "$store" diff --cached --quiet && \
     [[ -z "$(git -C "$store" ls-files --others --exclude-standard)" ]]; then
    echo "Status:   clean"
  else
    echo "Status:   dirty"
    git -C "$store" status --short
  fi

  local branch
  branch="$(git -C "$store" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")"
  [[ "$branch" == "HEAD" ]] && branch="detached"
  echo "Branch:   $branch"

  # Check behind from last fetch (no network call)
  local behind=0
  if git -C "$store" rev-parse --verify origin/main &>/dev/null; then
    behind="$(git -C "$store" rev-list --count HEAD..origin/main 2>/dev/null || echo 0)"
  fi
  [[ "$behind" -gt 0 ]] && echo "Behind:   $behind commit(s)"
}

# ── config ──────────────────────────────────────────────────────────

cmd_config() {
  ensure_folio_home
  local key="${1:-}"
  local value="${2:-}"

  if [[ -z "$key" ]]; then
    # Print all
    cat "$CONFIG_FILE"
    return 0
  fi

  if [[ -z "$value" ]]; then
    # Get
    read_config "$key"
    return 0
  fi

  # Set
  if grep -q "^$key:" "$CONFIG_FILE"; then
    sed -i '' "s|^$key:.*|$key: $value|" "$CONFIG_FILE"
  else
    echo "$key: $value" >> "$CONFIG_FILE"
  fi
}

# ── dispatch ───────────────────────────────────────────────────────

case "${1:-}" in
  init)   shift; cmd_init "$@" ;;
  sync)   shift; cmd_sync "$@" ;;
  list)   shift; cmd_list "$@" ;;
  status) shift; cmd_status "$@" ;;
  config) shift; cmd_config "$@" ;;
  *)
    cat <<EOF
folio — knowledge management over git

Usage:
  folio init [--label <n>]  Initialize a store for this project
  folio sync              Push draft PR (create or update)
  folio sync -m "msg"     With inline message
  folio list              List all stores (hash → label)
  folio status            Show current project/store status
  folio config            Show global config
  folio config <key>      Get a config value
  folio config <key> <v>  Set a config value

Edits happen in $STORE_DIR/<name>/leaves/.
folio sync opens a draft PR; you merge when ready.
EOF
    exit 1
    ;;
esac
